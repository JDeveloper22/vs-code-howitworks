    "configuration": {
      "title": "%config.title%",
      "properties": {
        "howItWorks.ai.provider": {
          "type": "string",
          "enum": [
            "openai",
            "ollama"
          ],
          "default": "openai",
          "description": "%config.ai.provider.description%"
        },
        "howItWorks.ai.model": {
          "type": "string",
          "default": "gpt-4o-mini",
          "description": "%config.ai.model.description%"
        },
        "howItWorks.ai.baseUrl": {
          "type": "string",
          "default": "",
          "description": "%config.ai.baseUrl.description%"
        },
        "howItWorks.ai.temperature": {
          "type": "number",
          "default": 0.2,
          "minimum": 0,
          "maximum": 2,
          "description": "%config.ai.temperature.description%"
        },
        "howItWorks.ai.maxSourceCharacters": {
          "type": "number",
          "default": 20000,
          "minimum": 1000,
          "description": "%config.ai.maxSourceCharacters.description%"
        },
        "howItWorks.ai.language": {
          "type": "string",
          "default": "Auto",
          "enum": [
            "Auto",
            "English",
            "Spanish",
            "French",
            "German",
            "Italian",
            "Portuguese",
            "Chinese",
            "Japanese",
            "Korean"
          ],
          "description": "%config.ai.language.description%"
        }
      }
